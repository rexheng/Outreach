{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": ["public/data/**", "api/_*.py"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/explore", "dest": "/explore.html" },
    {
      "src": "/data/(.*)",
      "headers": { "Cache-Control": "public, max-age=86400, s-maxage=86400" },
      "continue": true
    }
  ]
}
